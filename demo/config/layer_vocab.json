{
  "layer_vocabularies": {
    "DLSS": {
      "description": "道路设施 - Road facilities",
      "expected_annotations": ["highway numbers", "road names", "road classifications"],
      "patterns": ["^G\\d+", "^S\\d+", "^X\\d+", "^国道", "^省道", "^县道", "^乡道"],
      "example_texts": ["G75", "G210", "S312", "国道319", "省道104"],
      "semantic_weight": 0.9
    },
    "GCD": {
      "description": "高程点 - Elevation points",
      "expected_annotations": ["elevation values in meters"],
      "patterns": ["^\\d+\\.?\\d*$"],
      "example_texts": ["524.3", "1024.8", "358.12"],
      "semantic_weight": 0.8
    },
    "DGX": {
      "description": "等高线 - Contour lines",
      "expected_annotations": ["contour interval values"],
      "patterns": ["^\\d{2,4}$"],
      "example_texts": ["520", "540", "560", "580"],
      "semantic_weight": 0.7
    },
    "JMD": {
      "description": "居民地 - Residential areas",
      "expected_annotations": ["building names", "village names", "place names"],
      "patterns": [],
      "example_texts": ["村委会", "小学", "卫生院", "广场"],
      "semantic_weight": 0.6
    },
    "SXSS": {
      "description": "水系设施 - Water systems",
      "expected_annotations": ["river names", "stream names", "water body names"],
      "patterns": [],
      "example_texts": ["东溪", "綦江", "水库"],
      "semantic_weight": 0.6
    },
    "GXYZ": {
      "description": "管线 - Pipelines",
      "expected_annotations": ["pipeline IDs", "pipe specifications"],
      "patterns": ["^DN\\d+", "^Φ\\d+"],
      "example_texts": ["DN200", "DN300", "Φ150"],
      "semantic_weight": 0.7
    },
    "comm_line": {
      "description": "通信线路 - Communication lines",
      "expected_annotations": ["line IDs", "cable specifications", "length values"],
      "patterns": ["^\\d+$", "^\\d+\\.?\\d*[kK]?[mM]$"],
      "example_texts": ["通信线路1", "24芯光缆", "1.5km"],
      "semantic_weight": 0.8
    }
  }
}
